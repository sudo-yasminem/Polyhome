<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/wallpapers"
    android:backgroundTint="#80FFFFFF"
    android:backgroundTintMode="src_over">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textPorte_garage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:paddingTop="100sp"
            android:paddingBottom="30sp"
            android:text="Ouverture Porte"
            android:textColor="@color/black"
            android:textSize="34sp"
            android:textStyle="bold" />

        <Switch
            android:id="@+id/toggle_portegarage"
            android:layout_width="wrap_content"
            android:layout_height="41dp"
            android:layout_gravity="center"
            android:layout_marginStart="4dp"
            android:layout_marginTop="80dp"
            android:layout_marginBottom="601dp"
            android:gravity="center"
            android:includeFontPadding="false"
            android:paddingTop="10sp"
            android:scaleX="3"
            android:scaleY="3"
            android:textSize="24sp"
            android:thumbTint="@android:color/holo_blue_dark"
            android:trackTint="#12445B" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>